{
    "compilerOptions": {
        "target": "es6",
        "lib": ["es6", "dom"],
        "module": "commonjs",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "rootDir": "./src",
        "declaration": true,
        "outDir": "./lib",
        "strict": true,
        "types": ["jest"]
    },
    "include": ["src"],
    "exclude": ["src/**/*.test.ts"]
}